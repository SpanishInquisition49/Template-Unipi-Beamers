% beamerthemeUnipi.sty
% Adattamento Unipi del tema UC Berkeley (v1.2, 5 gennaio 2021)
% Autori: Gabriele Scannagatti 2026

\ProvidesPackage{beamerthemeUnipi}

% ============================================================
% MATH
% ============================================================
\RequirePackage{mathtools}
\RequirePackage{amsthm}
\RequirePackage{amsfonts}
\RequirePackage{amssymb}
\RequirePackage{faktor}
\RequirePackage{tikz-cd}

% ============================================================
% LOG WARNINGS
% ============================================================
\RequirePackage{silence}
\WarningsOff[mathdesign/mdbch]


% ============================================================
% FONT
% ============================================================
\RequirePackage{fontspec}
\setmainfont{EB Garamond} % Titles
\setsansfont{Fira Sans}[Scale=MatchLowercase] % Body
\setmonofont{JetBrains Mono}[Scale=MatchLowercase]

% ============================================================
% IMAGES
% ============================================================
\RequirePackage{graphicx, wrapfig}
\graphicspath{{./images/}}

\RequirePackage{tikz}
\RequirePackage{tcolorbox}

% ============================================================
% MISCELLANEOUS
% ============================================================
\RequirePackage{ragged2e}
\RequirePackage{etoolbox}
\RequirePackage{epigraph}
\setlength\epigraphwidth{0.8\textwidth}
\setlength\epigraphrule{0pt}
\renewcommand{\textflush}{flushepinormal}

% ============================================================
% COLORS
% ============================================================

% BASE PALETTE
\definecolor{UnipiDark}{HTML}{003A66}    % titles,bold text
\definecolor{UnipiBlue}{HTML}{00508B}    % footer, official Unipi color
\definecolor{UnipiLight}{HTML}{1A6FA0}   % frame body

% TEXT ACCENTS
\definecolor{UnipiRed}{HTML}{8B1A00}     % error / negative / critical   (9.3:1)
\definecolor{UnipiGreen}{HTML}{1F6B41}   % succeess / positive / ok      (6.5:1)
\definecolor{UnipiOrange}{HTML}{B35900}  % warning / attention          (6.0:1)
\definecolor{UnipiTeal}{HTML}{006B6B}    % info / alternative to blue (6.8:1)
\definecolor{UnipiPurple}{HTML}{5B3A8B}  % info / special category (7.8:1)

% BACGROUND ACCENTS
\definecolor{UnipiRedBg}{HTML}{F7E6E1}
\definecolor{UnipiGreenBg}{HTML}{E1F0E8}
\definecolor{UnipiOrangeBg}{HTML}{FBEDDD}
\definecolor{UnipiPurpleBg}{HTML}{ECE5F7}
\definecolor{UnipiTealBg}{HTML}{DFF0F0}
\definecolor{UnipiBlueBg}{HTML}{DCE9F2}

% GREY
\definecolor{UnipiGrayDark}{HTML}{2B2F33}   % Alternative to Black
\definecolor{UnipiGray}{HTML}{5C6770}       % Secondary text
\definecolor{UnipiGrayMid}{HTML}{9AA5AC}    % lines, separator
\definecolor{UnipiGrayLight}{HTML}{E8EDF1}  % alternate tables neutral
\definecolor{UnipiGrayLighter}{HTML}{F4F6F8} % alternative page background

% FRAMES BACKGROUND
\definecolor{UnipiWhite}{HTML}{FFFFFF}      % standard white
\definecolor{UnipiOffWhite}{HTML}{FAFBFC}   % warm white
\definecolor{UnipiSlateBg}{HTML}{F4F7FA}    % light blue
\definecolor{UnipiDarkBg}{HTML}{0D2B45}     % dark background
\definecolor{UnipiDarkBgAlt}{HTML}{102338}  % neutral dark alternative

% TEXT FOR DARK BACKGROUND
\definecolor{UnipiTextOnDark}{HTML}{F4F7FA}     % primary
\definecolor{UnipiTextOnDarkDim}{HTML}{A9C1D6}  % secondary
\definecolor{UnipiAccentOnDark}{HTML}{5FA8D3}   % accents

% ============================================================
% LAYOUT
% ============================================================
\setbeamertemplate{navigation symbols}{}
\setbeamertemplate{caption}[numbered]
\setbeamersize{text margin left=2em, text margin right=2em}

% ============================================================
% BEAMER COLORS
% ============================================================

% Aliases
\colorlet{UnipiBgColor}{UnipiWhite}         % Background
\colorlet{UnipiTextColor}{UnipiLight}       % body text
\colorlet{UnipiTitleColor}{UnipiDark}       % titles
\colorlet{UnipiAccentColor}{UnipiBlue}      % accents
\colorlet{UnipiFooterColor}{UnipiBlue}      % lower footer color
\colorlet{UnipiTextOnAccent}{UnipiWhite}    % text on footer

\newcommand{\unipilight}{%
  \colorlet{UnipiBgColor}{UnipiWhite}
  \colorlet{UnipiTextColor}{UnipiLight}
  \colorlet{UnipiTitleColor}{UnipiDark}
  \colorlet{UnipiAccentColor}{UnipiBlue}
  \colorlet{UnipiFooterColor}{UnipiBlue}
  \colorlet{UnipiTextOnAccent}{UnipiWhite}
}
\newcommand{\unipidark}{%
  \colorlet{UnipiBgColor}{UnipiDarkBg}
  \colorlet{UnipiTextColor}{UnipiTextOnDark}
  \colorlet{UnipiTitleColor}{UnipiAccentOnDark}
  \colorlet{UnipiAccentColor}{UnipiAccentOnDark}
  \colorlet{UnipiFooterColor}{UnipiDarkBgAlt}
  \colorlet{UnipiTextOnAccent}{UnipiTextOnDark}
}

\setbeamercolor{titlelike}{fg=UnipiAccentColor}
\setbeamercolor{author}{fg=UnipiTitleColor}
\setbeamercolor{institute}{fg=UnipiTitleColor}
\setbeamercolor{date}{fg=UnipiAccentColor}
\setbeamercolor{normal text}{fg=UnipiTextColor, bg=UnipiBgColor}
\setbeamercolor{background canvas}{bg=UnipiBgColor}
\setbeamercolor{structure}{fg=UnipiAccentColor}
\setbeamercolor{block title}{fg=UnipiTitleColor}
\setbeamercolor{section in toc}{fg=UnipiTitleColor}
\setbeamercolor{subsection in toc}{fg=UnipiAccentColor}

% ============================================================
% BEAMER FONTS
% ============================================================
\setbeamerfont{title}{size=\Huge}
\setbeamerfont{author}{family=\rmfamily, shape=\scshape, size=\footnotesize}
\setbeamerfont{institute}{family=\rmfamily, shape=\scshape, size=\scriptsize}
\setbeamerfont{date}{family=\rmfamily, shape=\scshape, size=\scriptsize}
\setbeamerfont{frametitle}{family=\rmfamily, series=\mdseries, size=\Large}
\setbeamerfont{block title}{family=\rmfamily, size=\large}

% ============================================================
% TEMPLATE TITLE AND SUMMARY
% ============================================================
\setbeamertemplate{title page}{%
  % Central title and subtitle
  \vspace{0.12\paperheight}
  \begin{beamercolorbox}[wd=\textwidth, leftskip=0pt]{title}
    \usebeamerfont{title}\usebeamercolor[fg]{title}\inserttitle\par
    \ifx\insertsubtitle\@empty\else
      \vskip0.4em
      {\usebeamerfont{subtitle}\usebeamercolor[fg]{subtitle}\insertsubtitle\par}
    \fi
  \end{beamercolorbox}
  % Force the author name and date on the left bottom corner
  \begin{tikzpicture}[remember picture, overlay]
    \node [anchor=south west, inner sep=0pt] at ([xshift=0.03\paperwidth, yshift=0.03\paperheight]current page.south west) {%
      \begin{beamercolorbox}[wd=0.6\paperwidth, leftskip=0pt]{author}
        {\usebeamerfont{author}\color{white}\insertauthor}%
        \ifx\insertdate\@empty\else
           {\usebeamerfont{date}\color{white},\, \insertdate}%
        \fi
      \end{beamercolorbox}
    };
  \end{tikzpicture}
}

\setbeamertemplate{section in toc}[sections numbered]
\setbeamertemplate{subsection in toc}{%
  \leavevmode\leftskip=3.2em
  \rlap{\hskip-2em\inserttocsectionnumber.\inserttocsubsectionnumber}%
  \inserttocsubsection\par
}

% ============================================================
% FRAME TITLE
% ============================================================
\setbeamertemplate{frametitle}{\vskip0.06\paperheight\insertframetitle}

% VARIATIONS
\newcommand{\smallframetitle}{%
  \setbeamertemplate{frametitle}{\vskip0.15\paperheight\insertframetitle}%
  \setbeamerfont{frametitle}{size=\large, series=\bfseries}%
}
\newcommand{\normalframetitle}{%
  \setbeamertemplate{frametitle}{\vskip0.15\paperheight\insertframetitle}%
  \setbeamerfont{frametitle}{size=\LARGE, series=\mdseries}%
}

% ============================================================
% DOTTED LIST
% ============================================================
\setbeamertemplate{itemize item}{\textbullet}
\setbeamertemplate{itemize subitem}{--}
\setbeamertemplate{itemize subsubitem}{\textbullet}
\setlength{\leftmargini}{1.25em}
\setlength{\leftmarginii}{1em}
\setlength{\leftmarginiii}{1em}

% ============================================================
% BACKGROUND AND LOGO
% ============================================================
\pgfdeclareimage[height=0.10\paperheight]{logo}{images/marchio_unipi_orizz_white.png}

\setbeamertemplate{background}{%
  \begin{tikzpicture}[overlay, remember picture]
    \fill[UnipiFooterColor]
      (current page.south west)
      -- +(0, 0.08\paperheight)
      -- +(\paperwidth, 0.18\paperheight)
      -- (current page.south east)
      -- cycle;
    \node[
      anchor=south east, inner sep=0pt, draw=none,
      xshift=-0.018\paperheight, yshift=0.02\paperheight
    ] at (current page.south east) {\pgfuseimage{logo}};
  \end{tikzpicture}%
}

% ============================================================
% THANK YOU FRAME
% ============================================================
\newcommand{\unipithankyoutext}{Thanks for your attention}
\newcommand{\unipithankyousubtext}{}

\newcommand{\unipithankyouframe}[2][]{%
  \begin{frame}[plain, noframenumbering, label=thankyou]
    \begin{tikzpicture}[overlay, remember picture]
      \fill[UnipiFooterColor]
        ([yshift=-0.42\paperheight] current page.north east) --
        (current page.south east) --
        ([yshift=0.08\paperheight] current page.south west) --
        cycle;
      \node[anchor=south east, inner sep=0pt, draw=none,
            xshift=-0.018\paperheight, yshift=0.02\paperheight]
        at (current page.south east)
        {\pgfuseimage{logo}};
    \end{tikzpicture}

    \vfill
    \begin{center}
      {\rmfamily\mdseries\fontsize{36}{42}\selectfont\color{UnipiTitleColor}%
        \ifstrempty{#2}{\unipithankyoutext}{#2}}

      \vspace{0.05cm}
      {\color{UnipiAccentColor!50}\rule{0.5\textwidth}{0.5pt}}
      \vspace{0.6cm}

      \ifstrempty{#1}{}{%
        {\large\color{UnipiTextColor}#1}%
      }
    \end{center}
    \vfill
  \end{frame}
}
